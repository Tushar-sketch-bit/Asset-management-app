# Routes
# This file defines all application routes (Higher priority routes first)
# https://www.playframework.com/documentation/latest/ScalaRouting
# ~~~~

# An example controller showing a sample home page
GET     /                           controllers.HomeController.index()

# Map static resources from the /public folder to the /assets URL path
GET     /assets/*file               controllers.Assets.versioned(path="/public", file: Asset)

GET     /api/assets                controllers.AssetController.index()
GET     /api/assets/:id            controllers.AssetController.show(id: String)
GET     /api/assets/:id/history    controllers.AssetController.history(id: String)

GET     /api/assets/:id/assignments     controllers.AssetController.assignments(id: String)
GET     /api/assets/:id/assignments/:assignmentId    controllers.AssetController.assignmentDetails(id: String, assignmentId: String)

GET     /api/assets/:id/maintenance    controllers.AssetController.maintenance(id: String)

GET     /api/admin/manage            controllers.AdminController.manage()
GET     /api/admin/manage/:id        controllers.AdminController.manageId(id: String)
